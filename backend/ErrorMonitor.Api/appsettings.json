{
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Database=error_monitor;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "PermitLimit": 200,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "Privacy": {
    "SensitiveKeys": ["password", "token", "authorization", "secret", "apiKey"],
    "DisableFieldCapture": ["requestBody"]
  }
}
